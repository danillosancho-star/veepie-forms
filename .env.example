# ─────────────────────────────────────────────
# Veepie Forms — variáveis de ambiente
# Copie para .env e preencha os valores reais
# NUNCA comite o .env no git
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:5173        # URL do frontend (Vite dev server)
API_URL=http://localhost:3001        # URL do próprio backend

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # service_role key (não a anon key)

# JWT — token dos links de avaliação
JWT_SECRET=                          # string aleatória longa (min 64 chars)
JWT_EXPIRY_DEFAULT=72h

# Criptografia — para o monday_token em repouso
ENCRYPTION_KEY=                      # 32 bytes hex (openssl rand -hex 32)

# Monday.com — token de serviço (usuário de integração)
# NÃO usar token pessoal
MONDAY_SERVICE_TOKEN=

# E-mail (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@veepieforms.com.br
EMAIL_FROM_NAME=Veepie Forms

# ─────────────────────────────────────────────
# Frontend (prefixo VITE_ para expor ao browser)
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
